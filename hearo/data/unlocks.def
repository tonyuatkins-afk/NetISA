# unlocks.def - HEARO unlock matrix manifest.
#
# This file mirrors the table in src/unlock/unlock.c and is used by
# tools/gen_unlocks (planned, not in v1.0) to generate documentation. The
# canonical source is unlock.c; if these go out of sync the C wins.
#
# Format: <id>  <name>  <category>  <requirement-or-->
#         <description>
#
# Lines starting with # are ignored.

UL_FFT_256              "256-bin FFT"            VISUALIZERS  "requires FPU"
"Full spectrum analyzer."
UL_BIPARTITE_FFT        "64-bin bipartite FFT"   VISUALIZERS  -
"Spectrum without floating point. Always available."
UL_PLASMA               "Plasma"                 VISUALIZERS  "requires FPU"
"Sine-field demoscene effect."
UL_TUNNEL               "Tunnel"                 VISUALIZERS  "requires 386+ FPU"
"Z-shaded tunnel."
UL_PARTICLE             "Particle system"        VISUALIZERS  "requires 486+ FPU"
"Audio-reactive particles."
UL_FIRE                 "Fire"                   VISUALIZERS  "requires FPU"
"Classic Doom-style fire."
UL_WIREFRAME            "Wireframe 3D"           VISUALIZERS  "requires 486+ FPU"
"Beat-driven 3D wireframe."
UL_STOCHASTIC           "Stochastic particles"   VISUALIZERS  "FPU-less only"
"Probability-based visualizer with no multiplications."

UL_REALSOUND            "RealSound PWM"          AUDIO        -
"PC Speaker pulse-width modulation."
UL_TANDY_PSG            "Tandy / PCjr PSG"       AUDIO        "requires Tandy or PCjr"
"3-voice + noise mixer."
UL_COVOX                "Covox Speech Thing"     AUDIO        "requires Covox on LPT"
"8-bit DAC on the parallel port."
UL_DISNEY               "Disney Sound Source"    AUDIO        "requires Disney on LPT"
"7 kHz LPT DAC with FIFO."
UL_OPL2_MIDI            "OPL2 MIDI"              AUDIO        "requires AdLib/SB"
"9-channel FM MIDI."
UL_OPL3_MIDI            "OPL3 MIDI"              AUDIO        "requires OPL3 device"
"18-channel FM MIDI."
UL_CQM_FM               "CQM FM"                 AUDIO        "requires AWE64"
"Software OPL3 emulation on AWE64."
UL_SB_PCM               "Sound Blaster PCM"      AUDIO        "requires Sound Blaster"
"8-bit PCM playback."
UL_SB16_PCM             "SB16 16-bit PCM"        AUDIO        "requires SB16"
"16-bit stereo PCM playback."
UL_SB16_ASP             "SB16 ASP"               AUDIO        "requires SB16 ASP"
"Hardware DSP effects."
UL_GUS_HW_MIX           "GUS hardware mixing"    AUDIO        "requires GUS"
"32-voice zero-CPU mixing."
UL_GUS_MAX_LINEIN       "GUS MAX line-in"        AUDIO        "requires GUS MAX"
"16-bit recording and passthrough."
UL_AWE_SFONT            "SoundFont loading"      AUDIO        "requires AWE32/64"
"Custom instrument banks."
UL_MT32_MODE            "MT-32 mode"             AUDIO        "requires MT-32/CM-32L"
"LA synthesis timbres."
UL_SC55_MODE            "SoundCanvas mode"       AUDIO        "requires SC-55+"
"GS / GM / drum maps."
UL_XG_MODE              "XG mode"                AUDIO        "requires DB50XG/MU"
"Yamaha XG voices."
UL_AGOLD_DAC            "AdLib Gold DAC"         AUDIO        "requires AdLib Gold"
"12-bit stereo playback."
UL_PAS16                "Pro Audio Spectrum 16"  AUDIO        "requires PAS-16"
"Native 16-bit PCM and OPL3 stereo."
UL_ESS_NATIVE           "ESS native mode"        AUDIO        "requires ESS AudioDrive"
"ESFM and 6-bit ADPCM."
UL_TBEACH               "Turtle Beach DSP"       AUDIO        "requires TBeach MultiSound"
"56001 DSP wavetable."
UL_MPU401               "MPU-401 MIDI"           AUDIO        "requires MPU-401"
"External MIDI gateway."

UL_ADAPTIVE_CORDIC      "Adaptive CORDIC"        ARITHMETIC   "requires FPU"
"Dynamic-precision visualizer math."
UL_EXACT_MIX            "Software quire"         ARITHMETIC   "requires FPU + 256K XMS"
"256-bit accumulator for bit-exact mixing."
UL_LOG_EFFECTS          "Log-domain effects"     ARITHMETIC   "requires FPU"
"Compressor/limiter/EQ in log domain."
UL_SINC_RESAMPLE        "Sinc resampling"        ARITHMETIC   "requires FPU"
"High-quality resampling for streaming."
UL_KARAOKE              "Karaoke vocal removal"  ARITHMETIC   "requires FPU"
"Mid-side cancellation."
UL_PARAM_EQ             "Parametric EQ"          ARITHMETIC   "requires FPU"
"10-band parametric EQ."
UL_CONV_REVERB          "Convolution reverb"     ARITHMETIC   "requires Pentium FPU"
"Impulse-response reverb."
UL_STEREO_WIDE          "Stereo widening"        ARITHMETIC   "requires FPU"
"Haas-effect widener."
UL_GAMMA_DITHER         "Gamma dither"           ARITHMETIC   "requires FPU"
"sRGB-aware album-art dither."
